.glow{
position:absolute;
width:650px;
height:650px;
border-radius:50%;
background:radial-gradient(circle,#00f7ff22,transparent 70%);
filter:blur(40px);
animation:pulse 4s infinite alternate;
}

@keyframes pulse{
0%{transform:scale(1);}
100%{transform:scale(1.15);}
}

